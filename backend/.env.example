# ─────────────────────────────────────────────────────────
# VOXA — Backend Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# Groq API Key (FREE — get yours at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# LLM Model Configuration
# Primary: Mistral | Fallback: LLaMA 3
PRIMARY_MODEL=mistral-saba-24b
FALLBACK_MODEL=meta-llama/llama-4-scout-17b-16b-instruct

# Whisper Model Size (base.en, small.en, medium.en)
WHISPER_MODEL=base.en

# Server Configuration
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Data paths
DATA_DIR=../data

# JWT Secret (change for production!)
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
