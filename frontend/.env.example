# ─────────────────────────────────────────────────────────
# VOXA — Frontend Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# Backend REST API base URL
# Used for: POST /speech-to-text, POST /chat, GET /history
VITE_API_URL=http://localhost:8000/api

# Backend WebSocket base URL
# Used for: WS /stream (real-time token streaming)
VITE_WS_URL=ws://localhost:8000/api

# Set to "true" to use the built-in mock API (no backend required).
# Set to "false" (or remove) to connect to a real backend.
VITE_MOCK_API=true
